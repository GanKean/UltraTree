<Window x:Class="UltraTree.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="http://schemas.livecharts.com/2.0/wpf"
        Title="UltraTree"
        Height="900"
        Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Window.Resources>

        <!-- VS Code dark base -->
        <SolidColorBrush x:Key="AppBackground" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="PanelBackground" Color="#252526"/>
        <SolidColorBrush x:Key="CardBackground" Color="#2D2D30"/>
        <SolidColorBrush x:Key="SurfaceBackground" Color="#1F1F1F"/>
        <SolidColorBrush x:Key="HeaderBackground" Color="#2D2D30"/>

        <!-- Blue theme -->
        <SolidColorBrush x:Key="AccentBlue" Color="#072B47"/>
        <SolidColorBrush x:Key="AccentBlueHover" Color="#0B3A5E"/>
        <SolidColorBrush x:Key="AccentBlueSelected" Color="#11476F"/>
        <SolidColorBrush x:Key="BorderColor" Color="#0C4C7D"/>
        <SolidColorBrush x:Key="GridLineColor" Color="#0C4C7D"/>

        <!-- Text -->
        <SolidColorBrush x:Key="PrimaryText" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="MutedText" Color="#CFCFCF"/>

        <!-- Global text -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
        </Style>

        <!-- Borders -->
        <Style TargetType="Border">
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
        </Style>

        <!-- Buttons -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
            <Setter Property="TextElement.Foreground" Value="{StaticResource PrimaryText}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <!-- ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource PanelBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
        </Style>

        <!-- Menu -->
        <Style TargetType="Menu">
            <Setter Property="Background" Value="{StaticResource PanelBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="{StaticResource PanelBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
            <Setter Property="TextElement.Foreground" Value="{StaticResource PrimaryText}"/>
        </Style>

        <!-- StatusBar -->
        <Style TargetType="StatusBar">
            <Setter Property="Background" Value="{StaticResource PanelBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
        </Style>

        <!-- ProgressBar -->
        <Style TargetType="ProgressBar">
            <Setter Property="Background" Value="{StaticResource SurfaceBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource PanelBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="RowBackground" Value="{StaticResource PanelBackground}"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource SurfaceBackground}"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource GridLineColor}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource GridLineColor}"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentBlueHover}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentBlueSelected}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
            <Setter Property="BorderBrush" Value="{StaticResource GridLineColor}"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource HeaderBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

    </Window.Resources>

    <DockPanel Background="{StaticResource AppBackground}">

        <!-- Menu -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File"/>
            <MenuItem Header="_Options"/>
            <MenuItem Header="_View"/>
            <MenuItem Header="_Help"/>
        </Menu>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" />
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="Ready" />
            </StatusBarItem>
        </StatusBar>

        <!-- Top header -->
        <Border DockPanel.Dock="Top"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,0,0,1"
                Background="{StaticResource CardBackground}"
                Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="520"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left controls -->
                <Grid Grid.Column="0" Margin="0,0,10,0" Background="{StaticResource CardBackground}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Select:"
                                   Width="55"
                                   VerticalAlignment="Center"/>
                        <ComboBox Width="260"
                                  Height="26"
                                  ItemsSource="{Binding Drives}"
                                  SelectedItem="{Binding SelectedDrive}" />
                        <Button Content="Scan"
                                Width="80"
                                Height="28"
                                Margin="8,0,0,0"
                                Command="{Binding ScanCommand}" />
                        <Button Content="Cancel"
                                Width="80"
                                Height="28"
                                Margin="8,0,0,0"
                                Command="{Binding CancelCommand}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                Margin="0,0,0,8">
                        <TextBlock Text="Status:"
                                   Width="55"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding StatusText}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <ProgressBar Grid.Row="2"
                                 Height="18"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding ProgressPercent}" />
                </Grid>

                <!-- Center stats -->
                <Border Grid.Column="1"
                        MaxWidth="520"
                        HorizontalAlignment="Left"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1"
                        Background="{StaticResource CardBackground}"
                        Padding="10"
                        Margin="0,0,10,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="180"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Selection:" FontWeight="Bold" Grid.Row="0" Grid.Column="0"/>
                        <TextBlock Text="{Binding SelectionText}" FontWeight="Bold" Grid.Row="0" Grid.Column="1"/>

                        <TextBlock Text="Total Space:" Grid.Row="1" Grid.Column="0"/>
                        <TextBlock Text="{Binding TotalSpaceText}" Grid.Row="1" Grid.Column="1"/>

                        <TextBlock Text="Space Used:" Grid.Row="2" Grid.Column="0"/>
                        <TextBlock Text="{Binding SpaceUsedText}" Grid.Row="2" Grid.Column="1"/>

                        <TextBlock Text="Space Free:" Grid.Row="3" Grid.Column="0"/>
                        <TextBlock Text="{Binding SpaceFreeText}" Grid.Row="3" Grid.Column="1"/>
                    </Grid>
                </Border>

                <!-- Right branding -->
                <Border Grid.Column="2"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1"
                        Background="{StaticResource CardBackground}"
                        Padding="10">
                    <StackPanel>
                        <TextBlock Text="UltraTree"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="NTFS Disk Analyzer"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                        <TextBlock Text="Capstone Build"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main body -->
        <Grid Margin="8" Background="{StaticResource AppBackground}">
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="280"/>
            </Grid.RowDefinitions>

            <!-- Non-clickable header -->
            <Border Grid.Row="0"
                    Background="{StaticResource CardBackground}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1"
                    Padding="8,4"
                    Margin="0,0,0,8">
                <TextBlock Text="Tree View"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryText}"/>
            </Border>

            <Grid Grid.Row="1" Background="{StaticResource AppBackground}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- Left grid -->
                <Border Grid.Column="0"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1"
                        Background="{StaticResource PanelBackground}">
                    <DataGrid x:Name="FoldersGrid"
                              ItemsSource="{Binding TopFolders}"
                              SelectedItem="{Binding SelectedFolder}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              RowHeaderWidth="0"
                              CanUserResizeRows="False"
                              CanUserSortColumns="True"
                              MouseDoubleClick="FoldersGrid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Folder"
                                                Binding="{Binding DisplayName}"
                                                Width="3*"
                                                SortMemberPath="Path"/>
                            <DataGridTextColumn Header="% of Total Space"
                                                Binding="{Binding PercentOfParentText}"
                                                Width="*"
                                                SortMemberPath="PercentOfParent"/>
                            <DataGridTextColumn Header="Size"
                                                Binding="{Binding SizeHuman}"
                                                Width="*"
                                                SortMemberPath="Bytes"/>
                            <DataGridTextColumn Header="Allocated"
                                                Binding="{Binding AllocatedHuman}"
                                                Width="*"
                                                SortMemberPath="AllocatedBytes"/>
                            <DataGridTextColumn Header="Items"
                                                Binding="{Binding ItemCountText}"
                                                Width="*"
                                                SortMemberPath="ItemCount"/>
                            <DataGridTextColumn Header="Files"
                                                Binding="{Binding FileCountText}"
                                                Width="*"
                                                SortMemberPath="FileCount"/>
                            <DataGridTextColumn Header="Folders"
                                                Binding="{Binding FolderCountText}"
                                                Width="*"
                                                SortMemberPath="FolderCount"/>
                            <DataGridTextColumn Header="Modified"
                                                Binding="{Binding ModifiedText}"
                                                Width="*"
                                                SortMemberPath="Modified"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <GridSplitter Grid.Column="1"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Background="{StaticResource BorderColor}"/>

                <!-- Right grid -->
                <Border Grid.Column="2"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1"
                        Background="{StaticResource PanelBackground}">
                    <DataGrid x:Name="FilesGrid"
                              ItemsSource="{Binding TopFiles}"
                              SelectedItem="{Binding SelectedFile}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              RowHeaderWidth="0"
                              CanUserResizeRows="False"
                              CanUserSortColumns="True"
                              MouseDoubleClick="FilesGrid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Files"
                                                Binding="{Binding DisplayName}"
                                                Width="2*"
                                                SortMemberPath="Path"/>
                            <DataGridTextColumn Header="Percent"
                                                Binding="{Binding PercentText}"
                                                Width="*"
                                                SortMemberPath="PercentOfDrive"/>
                            <DataGridTextColumn Header="Size"
                                                Binding="{Binding SizeHuman}"
                                                Width="*"
                                                SortMemberPath="Bytes"/>
                            <DataGridTextColumn Header="Allocated"
                                                Binding="{Binding AllocatedHuman}"
                                                Width="*"
                                                SortMemberPath="AllocatedBytes"/>
                            <DataGridTextColumn Header="Modified"
                                                Binding="{Binding ModifiedText}"
                                                Width="*"
                                                SortMemberPath="Modified"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>

            <!-- Pie charts -->
            <Border Grid.Row="2"
                    Margin="0,8,0,0"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1"
                    Background="{StaticResource PanelBackground}">
                <Grid Background="{StaticResource PanelBackground}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Storage Usage Charts"
                               FontWeight="SemiBold"
                               Margin="8,6,0,0"
                               VerticalAlignment="Top"/>

                    <Grid Grid.Row="1" Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Folder pie chart -->
                        <Border Grid.Column="0"
                                BorderBrush="{StaticResource BorderColor}"
                                BorderThickness="1"
                                Background="{StaticResource SurfaceBackground}"
                                Padding="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Folder Storage Usage"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>

                                <lvc:PieChart Grid.Row="1"
                                              Series="{Binding FolderPieSeries}"
                                              LegendPosition="Right"
                                              TooltipTextSize="14"/>
                            </Grid>
                        </Border>

                        <!-- File pie chart -->
                        <Border Grid.Column="2"
                                BorderBrush="{StaticResource BorderColor}"
                                BorderThickness="1"
                                Background="{StaticResource SurfaceBackground}"
                                Padding="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="File Storage Usage"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>

                                <lvc:PieChart Grid.Row="1"
                                              Series="{Binding FilePieSeries}"
                                              LegendPosition="Right"
                                              TooltipTextSize="14"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>