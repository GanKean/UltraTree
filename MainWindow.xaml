<Window x:Class="UltraTree.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="UltraTree"
        Height="900"
        Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">

    <Window.Resources>

    <!-- VS Code dark base -->
    <SolidColorBrush x:Key="AppBackground" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="PanelBackground" Color="#252526"/>
    <SolidColorBrush x:Key="CardBackground" Color="#2D2D30"/>
    <SolidColorBrush x:Key="HeaderBackground" Color="#2D2D30"/>
    <SolidColorBrush x:Key="SurfaceBackground" Color="#1F1F1F"/>

    <!-- Your custom blue theme -->
    <SolidColorBrush x:Key="AccentBlue" Color="#072B47"/>
    <SolidColorBrush x:Key="AccentBlueHover" Color="#0B3A5E"/>
    <SolidColorBrush x:Key="AccentBlueSelected" Color="#11476F"/>

    <!-- Borders / lines -->
    <SolidColorBrush x:Key="BorderColor" Color="#072B47"/>
    <SolidColorBrush x:Key="GridLineColor" Color="#072B47"/>

    <!-- Text -->
    <SolidColorBrush x:Key="PrimaryText" Color="#D4D4D4"/>
    <SolidColorBrush x:Key="SecondaryText" Color="#9CDCFE"/>
    <SolidColorBrush x:Key="MutedText" Color="#A0A0A0"/>

    <!-- General text -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
    </Style>

    <!-- Borders -->
    <Style TargetType="Border">
        <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
    </Style>

    <!-- Buttons -->
    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource CardBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,4"/>
    </Style>

    <!-- ComboBox -->
    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource PanelBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
    </Style>

    <!-- Menu -->
    <Style TargetType="Menu">
        <Setter Property="Background" Value="{StaticResource PanelBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
    </Style>

    <Style TargetType="MenuItem">
        <Setter Property="Background" Value="{StaticResource PanelBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
    </Style>

    <!-- Status bar -->
    <Style TargetType="StatusBar">
        <Setter Property="Background" Value="{StaticResource PanelBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
    </Style>

    <!-- Progress bar -->
    <Style TargetType="ProgressBar">
        <Setter Property="Background" Value="{StaticResource SurfaceBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
    </Style>

    <!-- DataGrid -->
    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{StaticResource PanelBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
        <Setter Property="RowBackground" Value="{StaticResource PanelBackground}"/>
        <Setter Property="AlternatingRowBackground" Value="{StaticResource SurfaceBackground}"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource GridLineColor}"/>
        <Setter Property="VerticalGridLinesBrush" Value="{StaticResource GridLineColor}"/>
        <Setter Property="GridLinesVisibility" Value="All"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
    </Style>

    <!-- DataGrid rows -->
    <Style TargetType="DataGridRow">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource AccentBlueHover}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource AccentBlueSelected}"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- DataGrid headers -->
    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource HeaderBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
        <Setter Property="BorderThickness" Value="0,0,1,1"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- ScrollViewer / treemap area text borders stay dark -->
    <Style TargetType="GroupBox">
        <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
    </Style>

</Window.Resources>

    <DockPanel>

        <Menu DockPanel.Dock="Top" Background="#F0F0F0">
            <MenuItem Header="_File"/>
            <MenuItem Header="_Options"/>
            <MenuItem Header="_View"/>
            <MenuItem Header="_Help"/>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" />
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="Ready" />
            </StatusBarItem>
        </StatusBar>

        <Border DockPanel.Dock="Top"
                BorderBrush="#C8C8C8"
                BorderThickness="0,0,0,1"
                Background="#E9EEF4"
                Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="460"/>
                    <ColumnDefinition Width="620"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,10,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Select:"
                                   Width="55"
                                   VerticalAlignment="Center"/>
                        <ComboBox Width="260"
                                  Height="26"
                                  ItemsSource="{Binding Drives}"
                                  SelectedItem="{Binding SelectedDrive}" />
                        <Button Content="Scan"
                                Width="80"
                                Height="28"
                                Margin="8,0,0,0"
                                Command="{Binding ScanCommand}" />
                        <Button Content="Cancel"
                                Width="80"
                                Height="28"
                                Margin="8,0,0,0"
                                Command="{Binding CancelCommand}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                Margin="0,0,0,8">
                        <TextBlock Text="Status:"
                                   Width="55"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding StatusText}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <ProgressBar Grid.Row="2"
                                 Height="18"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding ProgressPercent}" />
                </Grid>

                <Border Grid.Column="1"
                        BorderBrush="#C8C8C8"
                        BorderThickness="1"
                        Background="#F4F7FA"
                        Padding="10"
                        Margin="0,0,10,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="180"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Selection:" FontWeight="Bold" Grid.Row="0" Grid.Column="0"/>
                        <TextBlock Text="{Binding SelectionText}" FontWeight="Bold" Grid.Row="0" Grid.Column="1"/>

                        <TextBlock Text="Total Space:" Grid.Row="1" Grid.Column="0"/>
                        <TextBlock Text="{Binding TotalSpaceText}" Grid.Row="1" Grid.Column="1"/>

                        <TextBlock Text="Space Used:" Grid.Row="2" Grid.Column="0"/>
                        <TextBlock Text="{Binding SpaceUsedText}" Grid.Row="2" Grid.Column="1"/>

                        <TextBlock Text="Space Free:" Grid.Row="3" Grid.Column="0"/>
                        <TextBlock Text="{Binding SpaceFreeText}" Grid.Row="3" Grid.Column="1"/>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        BorderBrush="#C8C8C8"
                        BorderThickness="1"
                        Background="#F8F8F8"
                        Padding="10">
                    <StackPanel>
                        <TextBlock Text="UltraTree"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="NTFS Disk Analyzer"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                        <TextBlock Text="Capstone Build"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="260"/>
            </Grid.RowDefinitions>

            <TabControl Grid.Row="0"
                        Background="#F0F0F0"
                        BorderThickness="0">
                <TabItem Header="Tree View"/>
                <TabItem Header="File View"/>
                <TabItem Header="About"/>
            </TabControl>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        BorderBrush="#BFBFBF"
                        BorderThickness="1"
                        Background="White">
                    <DataGrid x:Name="FoldersGrid"
                              ItemsSource="{Binding TopFolders}"
                              SelectedItem="{Binding SelectedFolder}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Vertical"
                              RowHeaderWidth="0"
                              CanUserResizeRows="False"
                              CanUserSortColumns="True"
                              MouseDoubleClick="FoldersGrid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Folder"
                                                Binding="{Binding DisplayName}"
                                                Width="3*"
                                                SortMemberPath="Path"/>
                            <DataGridTextColumn Header="% of Parent"
                                                Binding="{Binding PercentOfParentText}"
                                                Width="*"/>
                            <DataGridTextColumn Header="Size"
                                                Binding="{Binding SizeHuman}"
                                                Width="*"
                                                SortMemberPath="Bytes"/>
                            <DataGridTextColumn Header="Allocated"
                                                Binding="{Binding AllocatedHuman}"
                                                Width="*"
                                                SortMemberPath="AllocatedBytes"/>
                            <DataGridTextColumn Header="Items"
                                                Binding="{Binding ItemCountText}"
                                                Width="*"
                                                SortMemberPath="ItemCount"/>
                            <DataGridTextColumn Header="Files"
                                                Binding="{Binding FileCountText}"
                                                Width="*"
                                                SortMemberPath="FileCount"/>
                            <DataGridTextColumn Header="Folders"
                                                Binding="{Binding FolderCountText}"
                                                Width="*"
                                                SortMemberPath="FolderCount"/>
                            <DataGridTextColumn Header="Modified"
                                                Binding="{Binding ModifiedText}"
                                                Width="*"
                                                SortMemberPath="Modified"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <GridSplitter Grid.Column="1"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Background="#D0D0D0"/>

                <Border Grid.Column="2"
                        BorderBrush="#BFBFBF"
                        BorderThickness="1"
                        Background="White">
                    <DataGrid x:Name="FilesGrid"
                              ItemsSource="{Binding TopFiles}"
                              SelectedItem="{Binding SelectedFile}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Vertical"
                              RowHeaderWidth="0"
                              CanUserResizeRows="False"
                              CanUserSortColumns="True"
                              MouseDoubleClick="FilesGrid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Files"
                                                Binding="{Binding DisplayName}"
                                                Width="2*"
                                                SortMemberPath="Path"/>
                            <DataGridTextColumn Header="Percent"
                                                Binding="{Binding PercentText}"
                                                Width="*"/>
                            <DataGridTextColumn Header="Size"
                                                Binding="{Binding SizeHuman}"
                                                Width="*"
                                                SortMemberPath="Bytes"/>
                            <DataGridTextColumn Header="Allocated"
                                                Binding="{Binding AllocatedHuman}"
                                                Width="*"
                                                SortMemberPath="AllocatedBytes"/>
                            <DataGridTextColumn Header="Modified"
                                                Binding="{Binding ModifiedText}"
                                                Width="*"
                                                SortMemberPath="Modified"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>

            <Border Grid.Row="2"
                    Margin="0,8,0,0"
                    BorderBrush="#BFBFBF"
                    BorderThickness="1"
                    Background="White">
                <Grid>
                    <TextBlock Text="Treemap View"
                               FontWeight="SemiBold"
                               Margin="8,6,0,0"
                               VerticalAlignment="Top"/>

                    <ScrollViewer Margin="0,28,0,0"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  Background="#FAFAFA">
                        <ItemsControl ItemsSource="{Binding TreemapItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas Width="1200" Height="220"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                    <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                </Style>
                            </ItemsControl.ItemContainerStyle>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="{Binding Width}"
                                            Height="{Binding Height}"
                                            Background="{Binding Fill}"
                                            BorderBrush="White"
                                            BorderThickness="1"
                                            ToolTip="{Binding Tooltip}"
                                            MouseLeftButtonDown="TreemapItem_MouseLeftButtonDown">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Opacity" Value="1"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Opacity" Value="0.75"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <TextBlock Text="{Binding Label}"
                                                       Margin="4"
                                                       FontSize="11"
                                                       Foreground="Black"
                                                       TextTrimming="CharacterEllipsis"
                                                       Visibility="{Binding LabelVisibility}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>