<Window x:Class="UltraTree.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="UltraTree" Height="720" Width="1100"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <Border Padding="10" CornerRadius="8" BorderThickness="1">
            <DockPanel LastChildFill="True">

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="Drive:" VerticalAlignment="Center" Margin="0,0,8,0"/>

                    <ComboBox Width="140"
                              ItemsSource="{Binding Drives}"
                              SelectedItem="{Binding SelectedDrive}" />

                    <Button Content="Scan"
                            Margin="12,0,0,0"
                            Padding="12,6"
                            Command="{Binding ScanCommand}" />

                    <Button Content="Cancel"
                            Margin="8,0,0,0"
                            Padding="12,6"
                            Command="{Binding CancelCommand}" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Width="350">
                    <ProgressBar Height="16"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding ProgressPercent}" />

                    <TextBlock Text="{Binding StatusText}"
                               Margin="0,6,0,0"
                               TextWrapping="Wrap"
                               Opacity="0.85"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- MAIN TABLES -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Top Folders -->
            <GroupBox Header="Top Folders" Grid.Column="0">
                <DataGrid x:Name="FoldersGrid"
                          ItemsSource="{Binding TopFolders}"
                          SelectedItem="{Binding SelectedFolder}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserSortColumns="True"
                          GridLinesVisibility="None"
                          RowHeaderWidth="0"
                          AlternatingRowBackground="#F3F3F3"
                          MouseDoubleClick="FoldersGrid_MouseDoubleClick">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Size"
                                            Width="130"
                                            Binding="{Binding SizeHuman}"
                                            SortMemberPath="Bytes"/>

                        <DataGridTextColumn Header="Path"
                                            Width="*"
                                            Binding="{Binding Path}"
                                            SortMemberPath="Path"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <!-- Top Files -->
            <GroupBox Header="Top Files" Grid.Column="2">
                <DataGrid x:Name="FilesGrid"
                          ItemsSource="{Binding TopFiles}"
                          SelectedItem="{Binding SelectedFile}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserSortColumns="True"
                          GridLinesVisibility="None"
                          RowHeaderWidth="0"
                          AlternatingRowBackground="#F3F3F3"
                          MouseDoubleClick="FilesGrid_MouseDoubleClick">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Size"
                                            Width="130"
                                            Binding="{Binding SizeHuman}"
                                            SortMemberPath="Bytes"/>

                        <DataGridTextColumn Header="Path"
                                            Width="*"
                                            Binding="{Binding Path}"
                                            SortMemberPath="Path"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>

        <!-- DETAILS PANEL -->
        <Border Grid.Row="3" Margin="0,12,0,0" Padding="10" CornerRadius="8" BorderThickness="1">
            <DockPanel>
                <TextBlock Text="Details:"
                           FontWeight="Bold"
                           Margin="0,0,10,0"/>

                <TextBlock Text="{Binding SelectedDetailsText}"
                           TextWrapping="Wrap"
                           Opacity="0.85"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>